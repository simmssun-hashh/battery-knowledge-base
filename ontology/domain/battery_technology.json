    "rules": [
      {
        "id": "rule_diffusion_rate_performance",
        "description": "扩散系数决定倍率性能上限",
        "if": "material.hasDiffusionCoefficient < 1e-12 cm²/s",
        "then": "requires_nano_sizing AND requires_carbon_coating",
        "examples": [
          "LFP: D≈1e-14→必须纳米化+碳包覆",
          "NCM: D≈1e-9→不需特殊处理"
        ]
      },
      {
        "id": "rule_conductivity_additive",
        "description": "电子导电性决定导电剂需求",
        "if": "material.hasBandGap > 2 eV",
        "then": "requires_significant_conductive_additive",
        "examples": [
          "LCO: 带隙≈0→几乎不需导电剂",
          "LFP: 带隙≈3.7eV→需大量导电剂"
        ]
      },
      {
        "id": "rule_thermal_stability_voltage_tradeoff",
        "description": "高电压材料=低热稳定性（通用规律）",
        "if": "material.hasMaxVoltage > 4.0V",
        "then": "thermal_stability_decreased AND requires_electrolyte_oxidation_protection",
        "mechanism": "高电压下正极表面过渡金属催化电解液氧化"
      }
    ]
  },
