      {
        "id": "CarbocationIntermediate",
        "parent": "ReactiveIntermediates",
        "definition": "碳正离子(C⁺)：三配位碳+空p轨道，正极>4.3V溶剂氧化产物，Lewis酸催化重排→电解液老化",
        "key_attributes": [
          "generation:SET_oxidation>4.3V",
          "stability:3°>2°>1°",
          "pathway:PF5_catalyzed_rearrangement",
          "outcome:CEI_growth+solvent_drying"
        ]
      },
      {
        "id": "CarbanionIntermediate",
        "parent": "ReactiveIntermediates",
        "definition": "碳负离子(C⁻)：三配位碳+孤对电子，EC还原开环产物等价物，LEDC/SEI无机相碳源",
        "key_attributes": [
          "generation:EC_reduction<0.8V",
          "stability:-I_substituents",
          "pathway:Li+_pairing→LEDC_precipitation",
          "pKa_alpha_C_H~35"
        ]
      },
      {
        "id": "FreeRadicalIntermediate",
        "parent": "ReactiveIntermediates",
        "definition": "自由基(C·)：7电子物种，EC还原自由基阴离子→开环自由基→二聚/链转移→SEI有机聚合物层",
        "key_attributes": [
          "generation:SET_reduction_0.5-1.5V",
          "BDE_CH3-H_439kJ_mol",
          "steady_state_conc_10nM",
          "termination:combination_vs_disproportionation"
        ]
      },
      {
        "id": "CarbeneIntermediate",
        "parent": "ReactiveIntermediates",
        "definition": "卡宾(:CR₂)：二价碳6电子物种，热失控>200°C时碳酸酯α-消除产物，C-H插入→自由基链爆炸→热失控不可逆",
        "key_attributes": [
          "generation:thermal_alpha_elimination>200C",
          "singlet_vs_triplet_dE_38kJ_mol",
          "pathway:C-H_insertion→radical_amplification",
          "role:thermal_runaway_trigger"
        ]
      },
      {
        "id": "PhononThermalProperty",
        "parent": "PhysicalLaw",
        "definition": "声子热学性质：Debye温度/热膨胀Grüneisen参数/声子热导率—支配电芯热管理的第一性物理",
        "subclasses": [
          "DebyeTemperature",
          "GruneisenParameter",
          "PhononThermalConductivity"
        ],
        "source": "Kittel Ch5 Phonons II: Thermal Properties"
      },
      {
        "id": "DebyeTemperature",
        "parent": "PhononThermalProperty",
        "definition": "声子谱截止频率的温度等价参数θ_D=ℏω_D/k_B，决定低温比热和声子硬度",
        "key_equation": "C_V=(12π⁴/5)Nk_B(T/θ_D)³ (T≪θ_D)"
      },
      {
        "id": "GruneisenParameter",
        "parent": "PhononThermalProperty",
        "definition": "γ=-d(ln ω)/d(ln V)，表征非谐性强度与热膨胀—材料热-力耦合的单一标量判据",
        "key_equation": "α=γ·C_V·κ_T/(3V)"
      },
      {
        "id": "PhononThermalConductivity",
        "parent": "PhononThermalProperty",
        "definition": "声子气体模型κ=(1/3)C_V·v_s·ℓ，受Umklapp/边界/缺陷三种散射限制",
        "key_equation": "κ=(1/3)C_V v_s ℓ"
      }
    ],
