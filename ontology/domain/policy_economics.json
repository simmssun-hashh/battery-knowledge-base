    "classes": [
      {
        "id": "PolicyInstrument",
        "label": "政策工具",
        "parent": "Thing",
        "definition": "政府/监管机构影响产业行为的政策手段",
        "subclasses": ["CarbonMarket", "ElectricityPricing", "SubsidyPolicy", "RecyclingRegulation"]
      },
      {
        "id": "CarbonMarket",
        "label": "碳市场",
        "parent": "PolicyInstrument",
        "key_mechanisms": ["中国ETS(全国碳市场覆盖电力)", "EU CBAM(对电池出口影响)", "碳足迹核算(欧盟电池法规)"],
        "cn_expansion": "后续扩至钢铁/水泥/铝"
      },
      {
        "id": "ElectricityPricing",
        "label": "电价机制",
        "parent": "PolicyInstrument",
        "key_factors": ["峰谷价差(鸭子曲线效应)", "分时电价(各省差异)", "两部制电价(基本+电度)"],
        "storage_arbitrage_window": "2-3年(IRR从12%降至4.2%后的转型期)"
      },
      {
        "id": "SupplyChainRisk",
        "label": "供应链风险",
        "parent": "Thing",
        "definition": "关键电池原材料的地缘政治和市场风险",
        "key_materials": ["锂", "钴", "镍"],
        "cn_dominance": "中国掌握全球70%+锂电材料加工能力",
        "lithium_price_history": "60万→7万→反弹至近20万(2022-2026)"
      },
      {
        "id": "EconomicVariable",
        "label": "经济变量",
        "parent": "Thing",
        "definition": "影响电池产业链的经济参数",
        "key_variables": ["碳酸锂价格", "电价", "碳价", "补贴强度", "产能利用率"]
      }
    ],
    "properties": [
      {
        "id": "hasEffectiveDate",
        "label": "生效日期",
        "domain": "PolicyInstrument",
        "range": "date",
        "cardinality": "1"
      },
      {
        "id": "hasImpact",
        "label": "影响量化",
        "domain": "PolicyInstrument",
        "range": "string",
        "cardinality": "1",
        "description": "政策对行业/企业/技术的量化影响"
      },
      {
        "id": "hasPriceVolatility",
        "label": "价格波动率",
        "domain": "SupplyChainRisk",
        "range": "float",
        "unit": "%",
        "cardinality": "1"
      }
    ],
    "rules": [
      {
        "id": "rule_lithium_price_policy_coupling",
        "label": "锂价政策耦合规则",
        "if": "lithium_price > 200000 元/吨",
        "then": "alternative_chemistries_viability_improved AND policy_intervention_probability_high",
        "mechanism": "高价触发钠电替代加速+政府释放储备/放宽开采审批"
      },
      {
        "id": "rule_carbon_border_impact",
        "label": "碳边境影响规则",
        "if": "export_target == EU AND battery.carbon_footprint > threshold",
        "then": "CBAM levy applied AND competitiveness_decreased",
        "source": "EU CBAM 碳边境调节机制"
      },
      {
        "id": "rule_peak_valley_arbitrage_decline",
        "label": "峰谷套利衰退规则",
        "if": "solar_penetration > 30%",
        "then": "duck_curve_effect_accelerated AND peak_valley_spread_narrowing",
        "consequence": "储能IRR从12%降至4.2%"
      }
    ]
  },
