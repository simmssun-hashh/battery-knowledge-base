{
  "domain": "standards_registry",
  "name": "标准法规索引",
  "description": "已学全部动力电池/新能源汽车相关GB/T/IEC标准索引，关联到具体领域文件",
  "version": "V2.0",
  "last_updated": "2026-05-11T13:08:00Z",
  "ontology_model": "TBox+ABox",
  "tbox": {
    "description": "概念定义层：标准分类体系、标准间关系类型",
    "classes": [
      {
        "id": "Standard",
        "label": "标准",
        "parent": "Thing",
        "definition": "电池/新能源汽车相关的国家或国际技术标准",
        "subclasses": [
          "强制性国标",
          "推荐性国标",
          "国际标准"
        ],
        "key_properties": [
          "standard_id",
          "name",
          "type",
          "implement_date",
          "domain",
          "replaces"
        ]
      },
      {
        "id": "StandardThreshold",
        "label": "标准阈值",
        "parent": "Thing",
        "definition": "标准中定义的量化判定阈值",
        "key_properties": [
          "parameter",
          "value",
          "unit",
          "applicable_chemistry",
          "test_condition"
        ]
      },
      {
        "id": "StandardRelation",
        "label": "标准间关系",
        "parent": "Thing",
        "definition": "标准之间的引用、替代、互补关系",
        "instances": [
          "replaces(替代)",
          "references(引用)",
          "complements(互补)",
          "extends(扩展)",
          "derives_from(派生)"
        ]
      }
    ],
    "properties": [
      {
        "id": "hasImplementDate",
        "label": "实施日期",
        "domain": "Standard",
        "range": "date",
        "cardinality": "1"
      },
      {
        "id": "hasThresholdValue",
        "label": "阈值",
        "domain": "StandardThreshold",
        "range": "float",
        "cardinality": "1"
      },
      {
        "id": "replacesStandard",
        "label": "替代标准",
        "domain": "Standard",
        "range": "Standard",
        "cardinality": "0..1"
      }
    ],
    "rules": [
      {
        "id": "rule_mandatory_compliance",
        "label": "强制合规规则",
        "if": "standard.type == '强制性国标'",
        "then": "compliance_mandatory AND non_compliance_illegal"
      },
      {
        "id": "rule_standard_family_resolution",
        "label": "标准体系冲突解决",
        "if": "standard_A.replaces == standard_B",
        "then": "standard_B.valid_until == standard_A.implement_date",
        "example": "GB 38031-2025替代GB 38031-2020→2026-07-01起2020版失效"
      },
      {
        "id": "rule_enterprise_threshold_priority",
        "label": "企业阈值优先规则",
        "if": "manufacturer_defined_threshold EXISTS",
        "then": "use manufacturer_defined_threshold OVER appendix_B_default",
        "source": "GB/T 44500-2024"
      }
    ]
  },
