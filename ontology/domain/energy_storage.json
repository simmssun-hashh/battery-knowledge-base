{
  "domain": "energy_storage",
  "name": "储能系统",
  "description": "工商业储能、电网储能、户用储能、储能经济性（IRR）、盈利模式",
  "version": "V2.0",
  "last_updated": "2026-06-16",
  "ontology_model": "TBox+ABox",
  "tbox": {
    "description": "概念定义层：储能系统架构、市场分类、经济模型的TBox定义",
    "classes": [
      {
        "id": "StorageSystem",
        "label": "储能系统",
        "parent": "Thing",
        "definition": "从电芯到站级控制的全层级储能系统",
        "subclasses": [
          "CIStorage",
          "GridStorage",
          "ResidentialStorage"
        ],
        "hierarchy": "cell → module → rack → container → station"
      },
      {
        "id": "CIStorage",
        "label": "工商业储能",
        "parent": "StorageSystem",
        "capacity_range": "100kW-10MW",
        "revenue_streams": [
          "峰谷套利",
          "需量管理",
          "需求响应"
        ],
        "irr_sensitivity": "峰谷价差从0.8→0.5元/kWh→IRR从12%→4.2%"
      },
      {
        "id": "GridStorage",
        "label": "电网侧储能",
        "parent": "StorageSystem",
        "capacity_range": "10MW+",
        "applications": [
          "调频",
          "调峰",
          "新能源消纳",
          "黑启动"
        ],
        "policy": "独立储能可参与电力现货市场"
      },
      {
        "id": "RevenueStream",
        "label": "收益来源",
        "parent": "Thing",
        "instances": [
          "PeakValleyArbitrage",
          "DemandResponseSubsidy",
          "CapacityLeasing",
          "AncillaryServices",
          "VPPAggregation"
        ],
        "key_properties": [
          "unit_price",
          "availability_guarantee",
          "policy_dependency"
        ]
      },
      {
        "id": "EconomicModel",
        "label": "经济性模型",
        "parent": "Thing",
        "definition": "储能项目投资回报计算模型",
        "key_inputs": [
          "battery_cost_per_kWh",
          "PCS_cost",
          "BOP_cost",
          "O&M_cost",
          "revenue_streams"
        ],
        "key_outputs": [
          "IRR",
          "payback_years",
          "NPV"
        ],
        "LFP_real_degradation": "年衰减2-3%/第5年仅剩85%"
      },
      {
        "id": "SodiumIonStorage",
        "label": "钠电储能",
        "parent": "CIStorage",
        "cost_advantage": "理论比LFP低30-40%，量产初期实际低10-15%",
        "cycle_life": "实验室3000-5000次 vs LFP已验6000-8000次",
        "low_temp_advantage": "-20°C正常充放电",
        "critical_window": "2026-2028最关键三年",
        "market_signal": "CATL 60GWh大单验证"
      }
    ],
    "properties": [
      {
        "id": "hasIRR",
        "label": "内部收益率",
        "domain": "EconomicModel",
        "range": "float",
        "unit": "%",
        "cardinality": "1"
      },
      {
        "id": "hasPeakValleySpread",
        "label": "峰谷价差",
        "domain": "CIStorage",
        "range": "float",
        "unit": "元/kWh",
        "cardinality": "1"
      },
      {
        "id": "hasPaybackYears",
        "label": "回本周期",
        "domain": "EconomicModel",
        "range": "float",
        "unit": "年",
        "cardinality": "1"
      },
      {
        "id": "hasCapacityDegradationRate",
        "label": "容量衰减率",
        "domain": "StorageSystem",
        "range": "float",
        "unit": "%/年",
        "cardinality": "1"
      }
    ],
    "rules": [
      {
        "id": "rule_irr_breakdown_duck_curve",
        "label": "鸭子曲线IRR崩塌规则",
        "if": "hasPeakValleySpread < 0.5 元/kWh",
        "then": "hasIRR < 5% AND requires_alternative_revenue",
        "alternatives": [
          "需求响应补贴(2-5元/度)",
          "容量租赁(降基本电费20-40%)",
          "调频服务(8-12%总投资)"
        ],
        "source": "工商储盈利模式分水岭"
      },
      {
        "id": "rule_sodium_storage_viability",
        "label": "钠电储能可行性判断",
        "if": "application.energy_density_requirement > 160 Wh/kg",
        "then": "sodium_ion_not_suitable",
        "sweet_spot": "大规模储能（对能量密度不敏感）"
      }
    ]
  },
