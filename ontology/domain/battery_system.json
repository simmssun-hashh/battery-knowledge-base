      },
      {
        "id": "SystemDesignConstraint",
        "label": "系统设计约束",
        "parent": "Thing",
        "definition": "电池系统设计的强制性工程约束",
        "subclasses": [
          "ThermalConstraint",
          "ElectricalConstraint",
          "MechanicalConstraint"
        ]
      },
      {
        "id": "SafetyStandard_System",
        "label": "安全标准(系统级)",
        "parent": "Thing",
        "definition": "适用于电池系统层级的安全标准",
        "instances": [
          "GB38031",
          "GB31467",
          "ISO26262"
        ]
      },
      {
        "id": "BatteryAI",
        "label": "电池AI算法",
        "parent": "Thing",
        "definition": "应用于电池寿命预测和安全监控的AI模型",
        "instances": [
          "BatteryGPT"
        ],
        "key_properties": [
          "model_architecture",
          "input_data",
          "output_metrics",
          "deployment_target"
        ]
      }
    ],
    "properties": [
      {
        "id": "hasMaxCellTemp",
        "label": "电芯最高温度",
        "domain": "ThermalConstraint",
        "range": "float",
        "unit": "°C",
        "cardinality": "1"
      },
      {
        "id": "hasCoolingTempDiff",
        "label": "冷却温差",
        "domain": "ThermalConstraint",
        "range": "float",
        "unit": "°C",
        "cardinality": "1"
      },
      {
        "id": "hasInsulationResistance",
        "label": "绝缘电阻",
        "domain": "ElectricalConstraint",
        "range": "float",
        "unit": "MΩ",
        "cardinality": "1",
        "voltage_dependent": {
          "400V": "≥500MΩ",
          "800V": "≥1000MΩ"
        }
      },
      {
        "id": "hasLeakRate",
        "label": "泄漏率",
        "domain": "MechanicalConstraint",
        "range": "float",
        "unit": "cc/min@3bar",
        "cardinality": "1"
      }
    ],
    "rules": [
      {
        "id": "rule_thermal_propagation_prevention",
        "label": "热蔓延防护规则",
        "if": "cell.thermal_runaway == true",
        "then": "contain_within_single_cell AND no_propagation_to_adjacent",
        "required_time": "24h(GB38031早期)→2h(GB38031-2025)"
      },
      {
        "id": "rule_hierarchy_building",
        "label": "系统层级构建规则",
        "chain": "cell --part_of--> module --part_of--> pack --part_of--> RESS",
        "constraint": "上层组件继承下层组件的所有安全约束"
      },
      {
        "id": "rule_cooling_plate_lifetime",
        "label": "液冷板耐久规则",
        "test_requirements": "热循环2000次(10-90°C) + 压力循环50000次(30-125kPa)",
        "leak_acceptance": "≤1.0cc/min@3bar"
      },
      {
        "id": "rule_BMS_protection_hierarchy",
        "label": "BMS保护层级规则",
        "protections": [
          "过放→过充→过温→过流→绝缘降低"
        ],
        "action": "任一保护触发→分级响应(预警→限功率→断高压)"
      }
    ]
  },
