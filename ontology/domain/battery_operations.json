    "description": "概念定义层：电池运营领域的核心业务对象、关系和决策规则",
    "classes": [
      {
        "id": "BatteryAsset",
        "label": "电池资产",
        "parent": "Thing",
        "definition": "作为独立资产的电池包，可跨车追踪、独立估值、金融化",
        "key_properties": [
          "asset_id",
          "chemistry",
          "rated_capacity_kWh",
          "manufacturing_date",
          "current_SOH"
        ]
      },
      {
        "id": "BaaSService",
        "label": "电池即服务",
        "parent": "Thing",
        "definition": "用户租赁电池而非购买的商业模式",
        "subclasses": [
          "BatterySwapService",
          "BatteryUpgradeService",
          "BatteryMaintenanceService"
        ]
      },
      {
        "id": "BatterySwapStation",
        "label": "换电站",
        "parent": "Thing",
        "definition": "换电网络节点，管理电池资产池和充电调度",
        "key_properties": [
          "station_id",
          "battery_inventory_count",
          "swap_frequency",
          "avg_SOC_distribution"
        ]
      },
      {
        "id": "CascadeApplication",
        "label": "梯次利用场景",
        "parent": "Thing",
        "definition": "退役动力电池在储能等低倍率场景的二次应用",
        "instances": [
          "通讯基站备电",
          "低速车",
          "家庭储能",
          "工商业储能"
        ],
        "screening_criteria": [
          "SOH >= 60%",
          "internal_resistance < 2x initial",
          "no_thermal_history"
        ]
      },
      {
        "id": "SOHPredictionModel",
        "label": "SOH预测模型",
        "parent": "Thing",
        "definition": "基于物理/数据/混合方法的电池健康状态预测算法",
        "instances": [
          "PhysicsBased",
          "LSTM",
          "CNN_LSTM",
          "HybridPhysicsAI",
          "BatteryGPT"
        ],
        "key_properties": [
          "input_data_type",
          "RMSE_percent",
          "min_data_requirement",
          "computational_cost"
        ]
      },
      {
        "id": "ResidualValueModel",
        "label": "残值评估模型",
        "parent": "Thing",
        "definition": "基于SOH衰减曲线+市场残值率+使用年限的电池残值计算模型",
        "key_factors": [
          "chemistry_type",
          "cycle_history",
          "temperature_history",
          "DOD_distribution"
        ],
        "uncertainties": [
          "技术快速迭代",
          "原材料价格波动",
          "梯次市场需求变化"
        ]
      }
    ],
    "properties": [
      {
        "id": "hasSOH",
        "label": "健康状态",
        "domain": "BatteryAsset",
        "range": "float",
        "unit": "%",
        "cardinality": "1"
      },
      {
        "id": "hasCycleCount",
        "label": "循环次数",
        "domain": "BatteryAsset",
        "range": "integer",
        "cardinality": "1"
      },
      {
        "id": "hasInternalResistance",
        "label": "内阻",
        "domain": "BatteryAsset",
        "range": "float",
        "unit": "mΩ",
        "cardinality": "1"
      },
      {
        "id": "hasSwapFrequency",
        "label": "换电频率",
        "domain": "BatterySwapStation",
        "range": "float",
        "unit": "次/天",
        "cardinality": "1"
      },
      {
        "id": "hasDegradationRate",
        "label": "年衰减率",
        "domain": "BatteryAsset",
        "range": "float",
        "unit": "%/年",
        "cardinality": "1",
        "typical": {
          "LFP": "2-3%/年",
          "NCM": "2-4%/年"
        }
      }
    ],
    "rules": [
      {
        "id": "rule_cascade_screening",
        "label": "梯次利用筛选规则",
        "if": "battery.hasSOH < 80% AND battery.hasSOH >= 60% AND battery.no_thermal_history",
        "then": "classify_as CascadeCandidate",
        "note": "SOH<60%→回收，而非梯次利用"
      },
      {
        "id": "rule_swap_battery_monitoring",
        "label": "换电电池监测规则",
        "if": "battery.in_service == true AND battery.mode == swap",
        "then": "requires_battery_level_monitoring AND requires_cross_vehicle_history_tracking",
        "source": "GB/T 45688 换电7项特殊适配"
      },
      {
        "id": "rule_residual_value_threshold",
        "label": "残值快速估值规则",
        "if": "battery.hasSOH < 80%",
        "then": "residual_value_rate < 50% of new"
      }
    ]
  },
