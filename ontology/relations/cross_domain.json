  "ontology_evolution": {
    "auto_discovery_rules": {
      "description": "新知识入库→自动匹配TBox类→自动归属到对应domain",
      "keyword_to_tbox_class": {
        "安全|热失控|起火|绝缘|故障|BMS报警": {
          "domain": "battery_safety",
          "class": "ThermalEvent|ElectricalEvent|InsulationEvent"
