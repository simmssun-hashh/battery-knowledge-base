          "domain": "battery_technology",
          "class": "CathodeMaterial|AnodeMaterial|ElectrochemicalPhenomenon"
        },
        "换电|梯次|残值|BaaS|运营|SOH": {
          "domain": "battery_operations",
          "class": "BatteryAsset|BatterySwapStation|SOHPredictionModel"
        },
        "储能|IRR|峰谷|容量租赁|调频|PCS": {
          "domain": "energy_storage",
          "class": "CIStorage|EconomicModel|RevenueStream"
        },
        "虚拟电厂|VPP|需求响应|电力市场|聚合": {
          "domain": "energy_internet",
          "class": "VirtualPowerPlant|DemandResponse"
        },
        "钠电|固态|硅基|量产|产业化|供应链": {
          "domain": "new_energy_market",
          "class": "SodiumIon|SolidState|SiliconAnode|SupplyChainSignal"
        },
        "碳交易|碳足迹|补贴|电价|政策|双积分": {
          "domain": "policy_economics",
          "class": "PolicyInstrument|CarbonMarket|ElectricityPricing"
        },
        "GB/T|GB |IEC |ISO |SAE ": {
          "domain": "standards_registry",
          "class": "Standard|StandardThreshold"
        }
      }
    },
    "tbox_consistency_rules": [
      "新实体必须归属到至少一个TBox类",
      "新属性必须声明domain和range",
      "新规则必须引用已存在的TBox类或属性",
      "跨域关系必须同时存在于tbox_relations和abox_relations中"
    ],
    "review_schedule": {
      "light_review": "每周日DREAMING Light → 扫描新学习文件 → 自动补充到对应TBox类",
      "deep_review": "每月第一个周日 → 检查TBox类覆盖完整性 → 识别新出现的知识类型需要新建类",
      "domain_expansion_trigger": "连续3个新学习文件无法匹配现有TBox类 → 自动提议新建类或domain"
    }
  },
  "methodology_references": [
    {
      "id": "METHOD001",
      "name": "构建业务本体语义for关联关系",
      "learned_date": "2026-05-11",
      "source": "飞书文档 OGxNdvzR5oebzRxCxYMcOwWAnme",
      "key_concepts": {
        "TBox": "术语集，定义概念与规则，不含具体数据（类比DB Schema/OOP Class）",
        "ABox": "断言集，真实业务数据，填充TBox结构（类比表数据/OOP Object）",
        "OWL": "建立在RDF上的高级本体语言，定义类/属性/关系/约束，适合建模TBox",
        "RDF": "W3C基础标准，三元组（主语-谓语-宾语）表达信息，适合表达ABox",
        "推理引擎": "HermiT/Pellet，自动推导隐含知识+验证模型一致性"
      },
      "toolchain": {
        "modeling": "Protégé（斯坦福开源本体编辑器）",
        "reasoning": "HermiT/Pellet推理引擎",
        "storage": "GraphDB（三元组库，隐式逻辑推导）/ Neo4j（属性图，显式关系分析）",
        "programming": "Owlready2（Python库，程序化本体操作）"
      },
      "application_to_existing_domains": {
        "蔚来能源云映射": {
          "TBox建模": "电池包类型、换电站类型、订单类型、客户类型",
          "ABox填充": "具体电池包实例、站点实例、充换电订单",
          "业务规则示例": [
            "可换电电池 ≡ BatteryPack ∧ (healthStatus ≥ 阈值) ∧ (cycleCount < 上限)",
            "紧急维保电池 ≡ BatteryPack ∧ (healthStatus < 阈值) ∧ (inService = true)"
          ]
        },
        "工具演进路径": "当前ontology/domain/*.json是轻量TBox，若需推理能力可考虑迁移到OWL+推理机"
      },
      "relationship_to_Palantir": {
        "TBox_ABox": "↔ Palantir Object Type + Link Type（语义层）",
        "推理引擎自动归类": "↔ Palantir Functions（业务逻辑单元）+ 实时沙盘",
        "OWL_RDF_Protege": "↔ 提供Palantir研究所缺的具体技术栈实现"
      }
    }
