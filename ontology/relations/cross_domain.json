      "to_class": "battery_operations.SOHPredictionModel",
      "type": "implements",
      "desc": "BMSAlgorithm(CoulombCounting/KalmanFilter等)在车端实现SOHPredictionModel的轻量版本"
    },
    {
      "id": "TCR013",
