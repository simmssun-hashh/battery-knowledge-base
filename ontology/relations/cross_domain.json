      "desc": "GB/T 45688 SafetyStandard要求BatterySwapStation做电池级监测（替代车辆级）",
      "abox_references": [
        "GB_T_45688-2025"
      ]
    },
    {
      "id": "TCR002",
      "from_class": "battery_technology.CathodeMaterial",
      "to_class": "battery_safety.BatteryChemistry",
      "type": "determines",
      "desc": "CathodeMaterial的热稳定性决定BatteryChemistry的安全阈值",
      "rule": "LFP.hasThermalStabilityRank=1 → max_temp=65°C; NCM.hasThermalStabilityRank=3 → max_temp=60°C"
    },
    {
      "id": "TCR003",
      "from_class": "new_energy_market.SodiumIon",
      "to_class": "energy_storage.CIStorage",
      "type": "enables",
      "desc": "SodiumIon低成本使CIStorage大规模部署经济可行",
      "rule": "SodiumIon.hasEnergyDensity ≤ 160Wh/kg → 适用场景=大规模储能"
    },
    {
      "id": "TCR004",
      "from_class": "energy_storage.CIStorage",
      "to_class": "energy_internet.VirtualPowerPlant",
      "type": "aggregates_into",
      "desc": "CIStorage聚合为VirtualPowerPlant参与电力市场",
      "rule": "100个×100MWh CIStorage=10GWh VirtualPowerPlant等效容量"
    },
    {
      "id": "TCR005",
      "from_class": "policy_economics.ElectricityPricing",
      "to_class": "energy_storage.EconomicModel",
      "type": "drives",
      "desc": "峰谷价差(ElectricityPricing)是EconomicModel.hasIRR的核心变量",
      "rule": "IF hasPeakValleySpread < 0.5元/kWh THEN hasIRR < 5%"
    },
    {
      "id": "TCR006",
      "from_class": "battery_technology.SEIFormation",
      "to_class": "battery_operations.SOHPredictionModel",
      "type": "mechanism_of",
      "desc": "SEI持续增厚是SOH衰减的物理根源，SOHPredictionModel需捕捉SEI阻抗演化"
    },
    {
      "id": "TCR007",
      "from_class": "battery_safety.ThermalRunawayEvent",
      "to_class": "battery_technology.CathodeMaterial",
      "type": "constrained_by",
      "desc": "ThermalRunawayEvent的2h不起火要求倒逼隔热设计",
      "rule": "GB 38031-2025: hasThermalRunawayDelay=2h"
    },
    {
      "id": "TCR008",
      "from_class": "new_energy_market.SiliconAnode",
      "to_class": "battery_technology.AnodeMaterial",
      "type": "extends",
      "desc": "SiliconAnode.hasCapacity=4200mAh/g 远超 Graphite.hasCapacity=372mAh/g",
      "constraint": "hasVolumeExpansion=300% → 需纳米化+预锂化"
    },
    {
      "id": "TCR009",
      "from_class": "standards_registry.Standard",
      "to_class": "battery_safety.SafetyStandard",
      "type": "instance_of",
      "desc": "standards_registry中的Standard实例属于battery_safety.SafetyStandard的子类",
      "rule": "强制性国标.hasImplementDate → 到期自动替代旧标准"
    },
    {
      "id": "TCR010",
      "from_class": "battery_operations.BatteryAsset",
      "to_class": "battery_operations.CascadeApplication",
      "type": "transitions_to",
      "desc": "BatteryAsset.hasSOH<80%→CascadeApplication; hasSOH<60%→回收",
      "rule": "rule_cascade_screening in battery_operations"
    },
    {
      "id": "TCR011",
      "from_class": "policy_economics.SupplyChainRisk",
      "to_class": "new_energy_market.SodiumIon",
      "type": "accelerates",
      "desc": "碳酸锂价格波动(SupplyChainRisk)加速SodiumIon产业化进程",
      "rule": "IF lithium_price > 200000元/吨 THEN sodium_ion_viability_improved"
    },
    {
      "id": "TCR012",
